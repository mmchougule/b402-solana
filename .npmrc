# Keep platform-specific native binaries in their parent package's node_modules
# so a hoisted higher-version binary doesn't get loaded by a lower-version
# host (the "Host version 0.21.5 does not match binary version 0.27.7"
# vitest/esbuild failure mode).
public-hoist-pattern[]=!@esbuild/*
public-hoist-pattern[]=!@swc/core-*
