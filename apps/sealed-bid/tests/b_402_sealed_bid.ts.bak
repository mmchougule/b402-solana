// End-to-end sealed-bid pair-match test.
//
// Two bidders each encrypt a `SwapIntent` to the MXE pubkey, submit the
// pair via the on-chain `submit_pair` ix, wait for the MPC callback,
// and verify the emitted `PairMatched` event matches the expected
// clearing terms.
//
// Run:
//   anchor test --skip-build --skip-deploy (after `arcium deploy`)
//   or
//   pnpm exec ts-node tests/b_402_sealed_bid.ts

import * as anchor from "@coral-xyz/anchor";
import { Program } from "@coral-xyz/anchor";
import { PublicKey } from "@solana/web3.js";
import { B402SealedBid } from "../target/types/b_402_sealed_bid";
import { randomBytes } from "crypto";
import {
  awaitComputationFinalization,
  getArciumEnv,
  getCompDefAccOffset,
  getArciumAccountBaseSeed,
  getArciumProgramId,
  getArciumProgram,
  uploadCircuit,
  RescueCipher,
  deserializeLE,
  getMXEPublicKey,
  getMXEAccAddress,
  getMempoolAccAddress,
  getCompDefAccAddress,
  getExecutingPoolAccAddress,
  getComputationAccAddress,
  getClusterAccAddress,
  getLookupTableAddress,
  x25519,
} from "@arcium-hq/client";
import * as fs from "fs";
import * as os from "os";
import { expect } from "chai";

// Mint registry — keep aligned with the off-chain settlement layer.
// 1-byte IDs map to real Solana mints. v1 demo uses 3 entries.
const MINT_USDC = 0;
const MINT_SOL = 1;
const MINT_BONK = 2;

describe("B402SealedBid — pairwise match", () => {
  anchor.setProvider(anchor.AnchorProvider.env());
  const program = anchor.workspace.B402SealedBid as Program<B402SealedBid>;
  const provider = anchor.getProvider();
  const arciumProgram = getArciumProgram(provider as anchor.AnchorProvider);

  type Event = anchor.IdlEvents<(typeof program)["idl"]>;
  const awaitEvent = async <E extends keyof Event>(
    eventName: E,
  ): Promise<Event[E]> => {
    let listenerId: number;
    const event = await new Promise<Event[E]>((res) => {
      listenerId = program.addEventListener(eventName, (event) => {
        res(event);
      });
    });
    await program.removeEventListener(listenerId!);
    return event;
  };

  const arciumEnv = getArciumEnv();
  const clusterAccount = getClusterAccAddress(arciumEnv.arciumClusterOffset);

  it("matches complementary intents — A wants SOL for USDC, B wants USDC for SOL", async () => {
    const owner = readKpJson(`${os.homedir()}/.config/solana/id.json`);

    // Comp_def is initialized as part of `arcium deploy` — skip
    // initMatchPairCompDef here to avoid AccountAlreadyInUse (System 0x0).
    // If you wipe state and need to reinit, restore the call below.
    // const initSig = await initMatchPairCompDef(program, owner);

    const mxePublicKey = await getMXEPublicKeyWithRetry(
      provider as anchor.AnchorProvider,
      program.programId,
    );
    console.log("  MXE x25519 pubkey:", Buffer.from(mxePublicKey).toString("hex"));

    // ---- Bidder A: 100 USDC → SOL, min 0.45 SOL ----
    const aIntent = {
      bidIdx: 1n,
      inMint: BigInt(MINT_USDC),
      outMint: BigInt(MINT_SOL),
      inAmount: 100_000_000n, // 100 USDC (6 decimals)
      minOut: 450_000_000n,   // 0.45 SOL (9 decimals)
    };
    const a = encryptIntent(aIntent, mxePublicKey);

    // ---- Bidder B: 0.5 SOL → USDC, min 95 USDC ----
    const bIntent = {
      bidIdx: 2n,
      inMint: BigInt(MINT_SOL),
      outMint: BigInt(MINT_USDC),
      inAmount: 500_000_000n, // 0.5 SOL
      minOut: 95_000_000n,    // 95 USDC
    };
    const b = encryptIntent(bIntent, mxePublicKey);

    // Mints complement: A in=USDC, B out=USDC; A out=SOL, B in=SOL ✓
    // A min 0.45 SOL ≤ B's 0.5 SOL ✓
    // B min 95 USDC ≤ A's 100 USDC ✓
    // Expected: matched = 1; cleared at full sizes.

    const pairMatchedPromise = awaitEvent("pairMatched");
    const computationOffset = new anchor.BN(randomBytes(8), "hex");

    // Catch + inspect the real error. web3.js 1.98 masks errors as
    // "Unknown action 'undefined'" when SendTransactionError is built
    // without an action field. Use .simulate() first to get the real
    // on-chain error logs.
    let queueSig: string;
    try {
      console.log("Simulating submit_pair to capture real error…");
      const sim = await program.methods
        .submitPair(
          computationOffset,
          Array.from(a.ciphertexts[0]),
          Array.from(a.ciphertexts[1]),
          Array.from(a.ciphertexts[2]),
          Array.from(a.ciphertexts[3]),
          Array.from(a.ciphertexts[4]),
          Array.from(a.publicKey),
          new anchor.BN(deserializeLE(a.nonce).toString()),
          Array.from(b.ciphertexts[0]),
          Array.from(b.ciphertexts[1]),
          Array.from(b.ciphertexts[2]),
          Array.from(b.ciphertexts[3]),
          Array.from(b.ciphertexts[4]),
          Array.from(b.publicKey),
          new anchor.BN(deserializeLE(b.nonce).toString()),
        )
        .accountsPartial({
          computationAccount: getComputationAccAddress(
            arciumEnv.arciumClusterOffset,
            computationOffset,
          ),
          clusterAccount,
          mxeAccount: getMXEAccAddress(program.programId),
          mempoolAccount: getMempoolAccAddress(arciumEnv.arciumClusterOffset),
          executingPool: getExecutingPoolAccAddress(arciumEnv.arciumClusterOffset),
          compDefAccount: getCompDefAccAddress(
            program.programId,
            Buffer.from(getCompDefAccOffset("match_pair")).readUInt32LE(),
          ),
        })
        .simulate({ commitment: "confirmed" });
      console.log("simulate result:", JSON.stringify(sim, null, 2).slice(0, 2000));
    } catch (simErr: any) {
      console.log("SIM ERROR raw:", simErr?.message);
      console.log("SIM ERROR keys:", Object.keys(simErr || {}));
      console.log("SIM RESPONSE:", JSON.stringify(simErr?.simulationResponse, null, 2));
      throw simErr;
    }

    queueSig = await program.methods
      .submitPair(
        computationOffset,
        // Bidder A
        Array.from(a.ciphertexts[0]), // bid_idx
        Array.from(a.ciphertexts[1]), // in_mint
        Array.from(a.ciphertexts[2]), // out_mint
        Array.from(a.ciphertexts[3]), // in_amount
        Array.from(a.ciphertexts[4]), // min_out
        Array.from(a.publicKey),
        new anchor.BN(deserializeLE(a.nonce).toString()),
        // Bidder B
        Array.from(b.ciphertexts[0]),
        Array.from(b.ciphertexts[1]),
        Array.from(b.ciphertexts[2]),
        Array.from(b.ciphertexts[3]),
        Array.from(b.ciphertexts[4]),
        Array.from(b.publicKey),
        new anchor.BN(deserializeLE(b.nonce).toString()),
      )
      .accountsPartial({
        computationAccount: getComputationAccAddress(
          arciumEnv.arciumClusterOffset,
          computationOffset,
        ),
        clusterAccount,
        mxeAccount: getMXEAccAddress(program.programId),
        mempoolAccount: getMempoolAccAddress(arciumEnv.arciumClusterOffset),
        executingPool: getExecutingPoolAccAddress(arciumEnv.arciumClusterOffset),
        compDefAccount: getCompDefAccAddress(
          program.programId,
          Buffer.from(getCompDefAccOffset("match_pair")).readUInt32LE(),
        ),
      })
      .rpc({ skipPreflight: true, commitment: "confirmed" });
    console.log("  submit_pair queue sig:", queueSig);

    const finalizeSig = await awaitComputationFinalization(
      provider as anchor.AnchorProvider,
      computationOffset,
      program.programId,
      "confirmed",
    );
    console.log("  finalize sig:", finalizeSig);

    const event = await pairMatchedPromise;
    console.log("  PairMatched event:", {
      matched: event.matched,
      aIdx: event.aIdx,
      bIdx: event.bIdx,
      aIn: event.aIn.toString(),
      aOut: event.aOut.toString(),
      bIn: event.bIn.toString(),
      bOut: event.bOut.toString(),
      aInMint: event.aInMint,
      aOutMint: event.aOutMint,
    });

    expect(event.matched).to.equal(1);
    expect(event.aIdx).to.equal(1);
    expect(event.bIdx).to.equal(2);
    expect(event.aIn.toString()).to.equal("100000000");
    expect(event.aOut.toString()).to.equal("500000000");
    expect(event.bIn.toString()).to.equal("500000000");
    expect(event.bOut.toString()).to.equal("100000000");
    expect(event.aInMint).to.equal(MINT_USDC);
    expect(event.aOutMint).to.equal(MINT_SOL);
  });

  // ---- helpers ----

  type Encrypted = {
    ciphertexts: Uint8Array[];
    publicKey: Uint8Array;
    nonce: Uint8Array;
  };

  function encryptIntent(
    intent: {
      bidIdx: bigint;
      inMint: bigint;
      outMint: bigint;
      inAmount: bigint;
      minOut: bigint;
    },
    mxePublicKey: Uint8Array,
  ): Encrypted {
    const privateKey = x25519.utils.randomSecretKey();
    const publicKey = x25519.getPublicKey(privateKey);
    const sharedSecret = x25519.getSharedSecret(privateKey, mxePublicKey);
    const cipher = new RescueCipher(sharedSecret);
    const nonce = randomBytes(16);
    const plaintext = [
      intent.bidIdx,
      intent.inMint,
      intent.outMint,
      intent.inAmount,
      intent.minOut,
    ];
    const ciphertexts = cipher.encrypt(plaintext, nonce);
    return { ciphertexts, publicKey, nonce };
  }

  async function initMatchPairCompDef(
    program: Program<B402SealedBid>,
    owner: anchor.web3.Keypair,
  ): Promise<string> {
    const baseSeedCompDefAcc = getArciumAccountBaseSeed(
      "ComputationDefinitionAccount",
    );
    const offset = getCompDefAccOffset("match_pair");

    const compDefPDA = PublicKey.findProgramAddressSync(
      [baseSeedCompDefAcc, program.programId.toBuffer(), offset],
      getArciumProgramId(),
    )[0];

    const mxeAccount = getMXEAccAddress(program.programId);
    const mxeAcc = await arciumProgram.account.mxeAccount.fetch(mxeAccount);
    const lutAddress = getLookupTableAddress(
      program.programId,
      mxeAcc.lutOffsetSlot,
    );

    const sig = await program.methods
      .initMatchPairCompDef()
      .accounts({
        compDefAccount: compDefPDA,
        payer: owner.publicKey,
        mxeAccount,
        addressLookupTable: lutAddress,
      })
      .signers([owner])
      .rpc({ commitment: "confirmed" });

    const rawCircuit = fs.readFileSync("build/match_pair.arcis");
    await uploadCircuit(
      provider as anchor.AnchorProvider,
      "match_pair",
      program.programId,
      rawCircuit,
      true,
      500,
      {
        skipPreflight: true,
        preflightCommitment: "confirmed",
        commitment: "confirmed",
      },
    );

    return sig;
  }
});

async function getMXEPublicKeyWithRetry(
  provider: anchor.AnchorProvider,
  programId: PublicKey,
  maxRetries: number = 30,
  retryDelayMs: number = 1000,
): Promise<Uint8Array> {
  for (let attempt = 1; attempt <= maxRetries; attempt++) {
    try {
      const mxePublicKey = await getMXEPublicKey(provider, programId);
      if (mxePublicKey) return mxePublicKey;
    } catch (e) {
      // retry
    }
    if (attempt < maxRetries) {
      await new Promise((r) => setTimeout(r, retryDelayMs));
    }
  }
  throw new Error(`Failed to fetch MXE public key after ${maxRetries} attempts`);
}

function readKpJson(path: string): anchor.web3.Keypair {
  const file = fs.readFileSync(path);
  return anchor.web3.Keypair.fromSecretKey(
    new Uint8Array(JSON.parse(file.toString())),
  );
}
