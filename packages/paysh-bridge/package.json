{
  "name": "@b402ai/paysh-bridge",
  "version": "0.0.1",
  "description": "Privacy bridge for x402 / pay.sh receivables on Solana — auto-shields incoming USDC into a b402 shielded balance",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmchougule/b402-solana.git",
    "directory": "packages/paysh-bridge"
  },
  "keywords": [
    "solana",
    "x402",
    "pay.sh",
    "privacy",
    "usdc",
    "b402"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@b402ai/solana": "workspace:*",
    "@solana/web3.js": "^1.95.8",
    "@solana/spl-token": "^0.4.9"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "fast-check": "^3.22.0",
    "@types/node": "^22.9.0"
  }
}
