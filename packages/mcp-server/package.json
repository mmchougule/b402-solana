{
  "name": "@b402ai/solana-mcp",
  "version": "0.0.18",
  "description": "Model Context Protocol server exposing the b402 Solana SDK as agent-callable tools (Claude Code, Cursor, any MCP runtime)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "b402-solana-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "circuits",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmchougule/b402-solana.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/mmchougule/b402-solana#readme",
  "bugs": "https://github.com/mmchougule/b402-solana/issues",
  "keywords": [
    "solana",
    "privacy",
    "mcp",
    "model-context-protocol",
    "agent",
    "claude-code",
    "cursor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --import tsx --enable-source-maps src/index.ts",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "copy-circuits": "bash scripts/copy-circuits.sh",
    "prepublishOnly": "pnpm run copy-circuits && pnpm run build"
  },
  "dependencies": {
    "@b402ai/solana": "workspace:*",
    "@b402ai/solana-prover": "workspace:*",
    "@b402ai/solana-shared": "workspace:*",
    "@lightprotocol/stateless.js": "0.23.0-beta.5",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.8",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
