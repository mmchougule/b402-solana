{
  "name": "@b402ai/solana",
  "version": "0.0.11",
  "description": "Private DeFi on Solana — shielded pool + composable adapters + agent-callable surface",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmchougule/b402-solana.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/mmchougule/b402-solana#readme",
  "bugs": "https://github.com/mmchougule/b402-solana/issues",
  "keywords": [
    "solana",
    "privacy",
    "zero-knowledge",
    "defi",
    "agent",
    "mcp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@b402ai/solana-shared": "workspace:*",
    "@b402ai/solana-prover": "workspace:*",
    "@solana/web3.js": "^1.95.8",
    "@solana/spl-token": "^0.4.9",
    "@noble/hashes": "^1.5.0",
    "@noble/ciphers": "^1.0.0",
    "@noble/curves": "^1.6.0",
    "circomlibjs": "^0.1.7",
    "@lightprotocol/stateless.js": "0.23.0-beta.5"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "fast-check": "^3.22.0",
    "@types/node": "^22.9.0"
  }
}
