# b402-agent template environment.
# Copy to .env and edit the paths below.

# Cluster: 'devnet' (default) or 'mainnet'. Mainnet flows are not yet wired
# in this template — keep devnet for the first run.
B402_CLUSTER=devnet

# Solana RPC. Default devnet works but is slow + rate-limited; use Helius or
# Triton for anything beyond the first dozen calls.
B402_RPC_URL=https://api.devnet.solana.com

# Path to your Solana CLI keypair (create with `solana-keygen new`).
# This signs shield/unshield transactions and pays priority fees.
B402_KEYPAIR_PATH=/Users/you/.config/solana/id.json

# Prover circuit artifacts. The b402-solana repo ships with throwaway-devnet
# artifacts under circuits/build/. For now the template expects you to point
# at a local clone.
#
# git clone https://github.com/mmchougule/b402-solana ../b402-solana
# B402_CIRCUITS_ROOT=../b402-solana/circuits/build
B402_CIRCUITS_ROOT=../b402-solana/circuits/build

# Mint of the token you want to shield. Default: devnet USDC.
B402_TOKEN_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
